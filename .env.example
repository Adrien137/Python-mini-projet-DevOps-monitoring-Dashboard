# Copier ce fichier en .env et remplir les valeurs
API_KEY=changeme123                  # clé d'accès à l'API (choisir une valeur)

# URL de l'API vue par le dashboard.
# - Exécution locale (make dev)    : http://localhost:8000
# - Exécution Docker (make up)     : surchargée automatiquement par
#                                     docker-compose.yml en http://api:8000
API_BASE_URL=http://localhost:8000
